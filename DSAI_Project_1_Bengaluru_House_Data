from ipywidgets import Dropdown, FloatSlider, IntSlider, interact, Output
from IPython.display import display
# Get unique locations from the processed dataframe
locations = sorted(df4['location'].unique().tolist())
# Create widgets
location_widget = Dropdown(
    options=locations,
    value=locations[0],
    description='Location:',
    disabled=False,
)
total_sqft_widget = FloatSlider(
    value=df4['total_sqft'].mean(),
    min=df4['total_sqft'].min(),
    max=df4['total_sqft'].max(),
    step=10.0,
    description='Total Sqft:',
    disabled=False,
    continuous_update=True,
    orientation='horizontal',
    readout=True,
    readout_format='.1f',
)
bath_widget = IntSlider(
    value=int(df4['bath'].mean()),
    min=int(df4['bath'].min()),
    max=int(df4['bath'].max()),
    step=1,
    description='Bathrooms:',
    disabled=False,
    continuous_update=True,
    orientation='horizontal',
    readout=True,
    readout_format='d',
)
bedroom_widget = IntSlider(
    value=int(df4['bedroom'].mean()),
    min=int(df4['bedroom'].min()),
    max=int(df4['bedroom'].max()),
    step=1,
    description='Bedrooms:',
    disabled=False,
    continuous_update=True,
    orientation='horizontal',
    readout=True,
    readout_format='d',
)
# Output widget to display predictions
output_area = Output()
# Define the interactive function
def interactive_predict(location, total_sqft, bath, bedroom):
    with output_area:
        output_area.clear_output()
        prediction = predict_price(location, total_sqft, bath, bedroom)
        print(f"Predicted Price: {prediction} Lakhs")
# Link widgets to the interactive function
interactive_ui = interact(
    interactive_predict,
    location=location_widget,
    total_sqft=total_sqft_widget,
    bath=bath_widget,
    bedroom=bedroom_widget
)
# Display the widgets and output area
display(interactive_ui)
display(output_area)
