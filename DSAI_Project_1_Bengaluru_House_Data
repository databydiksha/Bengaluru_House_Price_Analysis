def convert_sqft_to_num(x):
    if isinstance(x, float):
        return x

    tokens = x.split('-')

    if len(tokens) == 2:
        return (float(tokens[0]) + float(tokens[1])) / 2

    try:
        return float(x)
    except:
        return None
